name: '石墨文档'
desc: |-
  脚本解锁 石墨文档
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '解锁'
date: '2026-05-29'
version: '1.0.0'

http:
  mitm:
    - 'shimo.im'

  script:
    - match: https://shimo.im/lizard-api/users/me
      name: JS_SMWD
      type: response
      timeout: 60
      require-body: true

script-providers:
  JS_SMWD:
    url: https://raw.githubusercontent.com/alzuobaba/private-override/main/scripts/apps/JS_SMWD.js
    interval: 0
