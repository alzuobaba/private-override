    - ^https?:\/\/msync-im1-vip6-std\.easemob\.com\/ - reject-200
    - ^https?:\/\/market\.wsskj520\.cn\/ - reject-200
    - ^https?:\/\/api\.iegadp\.qq\.com\/ - reject-200
    - ^https?:\/\/pgdt\.ugdtimg\.com\/ - reject-200
    - ^https?:\/\/buysecm\.com\/ - reject-200
    - ^https?:\/\/mssdk\.volces\.com\/ - reject-200
    - ^https?:\/\/gw-w\.jiaoliuqu\.com\/admp\/v1\/Toutiao - reject-200
    - ^https?:\/\/googleads\.g\.doubleclick\.net\/pagead\/interaction\/ - reject-200
