    - ^https?:\/\/p6-ad-sign\.byteimg\.com\/ - reject-200
    - ^https?:\/\/p9-ad-sign\.byteimg\.com\/ - reject-200
    - ^https?:\/\/lf-cdn-tos\.bytescm\.com\/obj\/static\/ad\/ - reject-200

    # 字节其他广告域名
    - ^https?:\/\/.*\.bytedance\.com\/ - reject-200
    - ^https?:\/\/.*\.bytegoofy\.com\/ - reject-200
    - ^https?:\/\/.*\.byteorge\.com\/ - reject-200
    - ^https?:\/\/activity-ag\.awemeughun\.com\/ - reject-200
    - ^https?:\/\/.*\.fqnovel\.com\/ - reject-200
    - ^https?:\/\/.*\.fqnovelpic\.com\/ - reject-200

    # 快手广告
    - ^https?:\/\/open\.e\.kuaishou\.com\/rest\/ - reject-200
