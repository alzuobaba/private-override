name: '番茄小说去广告'
desc: |-
  番茄免费小说 去广告
  - 移除阅读页广告、开屏广告、各类弹窗推广
  - 拦截穿山甲/快手/京东/拼多多/百度等广告 SDK
  - 屏蔽运营活动、任务入口
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '去广告 / 净化'
date: '2026-06-02'
version: '1.0.0'

http:
  mitm:
    - default.ixigua.com
    - novelapp.ixigua.com
    - fqnovel.com
    - fqnovelpic.com
    - fqnovelvod.com
    - *.pstatp.com
    - *.pglstatp-toutiao.com
    - *.snssdk.com
    - *.zijieapi.com
    - *.pangolin-sdk-toutiao.com
    - *.pangolin-sdk-toutiao1.com
    - *.pangolin-sdk-toutiao-b.com
    - *.byteimg.com
    - *.bytegoofy.com
    - *.byteorge.com
    - *.ecombdapi.com
    - *.ecombdimg.com
    - *.bytedance.com
    - i-lq.snssdk.com
    - i.snssdk.com
    - is.snssdk.com
    - mcs.snssdk.com
    - security-lq.snssdk.com
    - gurd.snssdk.com
    - activity-ag.awemeughun.com
    - ads0-normal-lq.zijieapi.com
    - ads1-normal-lq.zijieapi.com
    - ads2-normal-lq.zijieapi.com
    - ads3-normal-lq.zijieapi.com
    - ads4-normal-lq.zijieapi.com
    - ads5-normal-lq.zijieapi.com
    - tnc0-aliec1.zijieapi.com
    - tnc0-aliec2.zijieapi.com
    - tnc0-aliec3.zijieapi.com
    - tnc1-aliec1.zijieapi.com
    - tnc1-aliec2.zijieapi.com
    - tnc1-aliec3.zijieapi.com
    - tnc2-aliec1.zijieapi.com
    - tnc2-aliec2.zijieapi.com
    - tnc2-aliec3.zijieapi.com
    - tnc3-aliec1.zijieapi.com
    - tnc3-aliec2.zijieapi.com
    - tnc3-aliec3.zijieapi.com
    - tnc3-aliec2.snssdk.com
    - tnc3-alisc1.snssdk.com
    - p6-ad-sign.byteimg.com
    - p9-ad-sign.byteimg.com
    - v6-novelapp.ixigua.com
    - sf3-ttcdn-tos.pstatp.com
    - lf-cdn-tos.bytescm.com
    - api-access.pangolin-sdk-toutiao.com
    - api-access.pangolin-sdk-toutiao1.com
    - api-access.pangolin-sdk-toutiao-b.com
    - open.e.kuaishou.com
    - p2-lm.adukwai.com
    - dig.bdurl.net
    - mobads.baidu.com
    - gdfp.gifshow.com
    - adim.pinduoduo.com
    - dsp-x.jd.com
    - 360buyimg.com
    - tobog.ctobsnssdk.com
    - ulogs.umeng.com
    - app-measurement.com
    - whoami.akamai.net
    - msync-im1-vip6-std.easemob.com
    - market.wsskj520.cn
    - pgdt.ugdtimg.com

  url-rewrite:
    # 番茄小说核心域名拦截
    - ^https?:\/\/.*default\.ixigua\.com\/ - reject-200
    - ^https?:\/\/.*novelapp\.ixigua\.com\/ - reject-200
    - ^https?:\/\/v6-novelapp\.ixigua\.com\/ - reject-200

    # 字节跳动广告 SDK
    - ^https?:\/\/.*\.snssdk\.com\/ - reject-200
    - ^https?:\/\/i-lq\.snssdk\.com\/ - reject-200
    - ^https?:\/\/i\.snssdk\.com\/ - reject-200
    - ^https?:\/\/is\.snssdk\.com\/ - reject-200
    - ^https?:\/\/mcs\.snssdk\.com\/ - reject-200
    - ^https?:\/\/security-lq\.snssdk\.com\/ - reject-200
    - ^https?:\/\/gurd\.snssdk\.com\/ - reject-200
    - ^https?:\/\/tnc3-aliec2\.snssdk\.com\/ - reject-200
    - ^https?:\/\/tnc3-alisc1\.snssdk\.com\/ - reject-200
    - ^https?:\/\/frontier-toutiao\.snssdk\.com\/ - reject-200
    - ^https?:\/\/toutiao-frontier\.snssdk\.com\/ - reject-200

    # zijieapi 广告接口
    - ^https?:\/\/.*\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads0-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads1-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads2-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads3-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads4-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/ads5-normal-lq\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc0-aliec1\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc0-aliec2\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc0-aliec3\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc1-aliec1\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc1-aliec2\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc1-aliec3\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc2-aliec1\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc2-aliec2\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc2-aliec3\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc3-aliec1\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc3-aliec2\.zijieapi\.com\/ - reject-200
    - ^https?:\/\/tnc3-aliec3\.zijieapi\.com\/ - reject-200

    # 穿山甲 SDK
    - ^https?:\/\/api-access\.pangolin-sdk-toutiao\.com\/api\/ad\/ - reject-200
    - ^https?:\/\/api-access\.pangolin-sdk-toutiao1\.com\/api\/ad\/ - reject-200
    - ^https?:\/\/api-access\.pangolin-sdk-toutiao-b\.com\/api\/ad\/union\/sdk\/ - reject-200
    - ^https?:\/\/log-api\.pangolin-sdk-toutiao-b\.com\/service - reject-200
    - ^https?:\/\/.*\.pangolin-sdk-toutiao.*\.com\/ - reject-200

    # 字节 CDN 广告资源
    - ^https?:\/\/.*\.pstatp\.com\/ - reject-200
    - ^https?:\/\/sf3-ttcdn-tos\.pstatp\.com\/ - reject-200
    - ^https?:\/\/.*\.pglstatp-toutiao\.com\/ - reject-200
