name: '蜗牛睡眠'
desc: |-
  脚本解锁 蜗牛睡眠
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '解锁'
date: '2026-05-29'
version: '1.0.0'

http:
  mitm:
    - snailsleep.net

  script:
    - match: ^https?:\/\/snailsleep\.net\/snail\/v\d\/profile\/get.
      name: JS-1_Snailsleep
      type: response
      timeout: 60
      require-body: true

script-providers:
  JS-1_Snailsleep:
    path: scripts/apps/JS-1_Snailsleep.js
    interval: 0
