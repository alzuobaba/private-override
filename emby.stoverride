name: 'Emby'
desc: |-
  脚本解锁 Emby
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '解锁'
date: '2026-05-29'
version: '1.0.0'

http:
  mitm:
    - mb3admin.com

  script:
    - match: ^http(s?):\/\/(www\.|)mb3admin\.com\/.*$
      name: JS_Emby
      type: response
      timeout: 10
      require-body: true

script-providers:
  JS_Emby:
    path: scripts/apps/JS_Emby.js
    interval: 0
