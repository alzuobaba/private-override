name: 'SoundCloud'
desc: |-
  脚本解锁 SoundCloud
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '解锁'
date: '2026-05-29'
version: '1.0.0'

http:
  mitm:
    - 'api-mobile.soundcloud.com'

  script:
    - match: https://api-mobile.soundcloud.com/configuration/ios
      name: JS_Soundcloud
      type: response
      timeout: 60
      require-body: true

script-providers:
  JS_Soundcloud:
    path: scripts/apps/JS_Soundcloud.js
    interval: 0
