name: '宜搜小说'
desc: |-
  脚本解锁 宜搜小说
author: alzuobaba
homepage: https://github.com/alzuobaba/private-override
category: '解锁'
date: '2026-05-29'
version: '1.0.0'

http:
  mitm:
    - api.ieasou.com

  script:
    - match: ^https?:\/\/api\.ieasou\.com\/api\/bookapp\/balance\.m?
      name: JS_YiSouXS
      type: response
      timeout: 60
      require-body: true

script-providers:
  JS_YiSouXS:
    path: scripts/apps/JS_YiSouXS.js
    interval: 0
